generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String        @id @default(uuid())
  name           String
  email          String        @unique
  password       String
  role           String        @default("STAFF")
  isActive       Boolean       @default(true)
  canViewHistory Boolean       @default(false)
  canViewSalary  Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  activityLogs   ActivityLog[]

  @@map("users")
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  detail    String?
  createdAt DateTime @default(now())

  @@map("activity_logs")
}

model Payroll {
  id           String   @id @default(uuid())
  employeeName String
  month        Int
  year         Int
  baseSalary   Float    @default(0)
  allowances   Float    @default(0)
  deductions   Float    @default(0)
  netSalary    Float    @default(0)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([employeeName, month, year])
  @@map("payrolls")
}

model CompanySetting {
  id               String   @id @default(uuid())
  name             String
  address          String
  email            String
  phone            String
  logoUrl          String?
  website          String?
  taxNumber        String?
  bankName         String?
  bankAccount      String?
  bankHolder       String?
  docNameSph       String?
  docPrefixSph     String?
  docNameInvoice   String?
  docPrefixInvoice String?
  docNameExpense   String?
  docPrefixExpense String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("company_settings")
}

model Client {
  id        String    @id @default(uuid())
  type      String    @default("COMPANY")
  name      String
  address   String
  email     String?
  phone     String?
  pic       String?
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sphs      Sph[]
  invoices  Invoice[]

  @@map("clients")
}

model Product {
  id           String        @id @default(uuid())
  name         String
  description  String?
  price        Float         @default(0)
  unit         String        @default("pcs")
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  sphItems     SphItem[]
  invoiceItems InvoiceItem[]

  @@map("products")
}

model Signature {
  id        String    @id @default(uuid())
  name      String
  title     String?
  imageUrl  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  sphs      Sph[]
  invoices  Invoice[]

  @@map("signatures")
}

model Sph {
  id           String     @id @default(uuid())
  number       String     @unique
  date         DateTime
  validUntil   DateTime?
  clientId     String
  client       Client     @relation(fields: [clientId], references: [id])
  items        SphItem[]
  subtotal     Float      @default(0)
  taxRate      Float      @default(0)
  taxAmount    Float      @default(0)
  total        Float      @default(0)
  notes        String?
  status       String     @default("DRAFT")
  openingText  String?
  closingText  String?
  headerColor  String?
  signerTitle  String?
  signatureId  String?
  signature    Signature? @relation(fields: [signatureId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("sphs")
}

model SphItem {
  id          String   @id @default(uuid())
  sphId       String
  sph         Sph      @relation(fields: [sphId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  name        String
  description String?
  quantity    Float    @default(1)
  unit        String   @default("pcs")
  price       Float    @default(0)
  total       Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("sph_items")
}

model Invoice {
  id           String        @id @default(uuid())
  number       String        @unique
  date         DateTime
  dueDate      DateTime
  clientId     String
  client       Client        @relation(fields: [clientId], references: [id])
  items        InvoiceItem[]
  subtotal     Float         @default(0)
  taxRate      Float         @default(0)
  taxAmount    Float         @default(0)
  total        Float         @default(0)
  paidAmount   Float         @default(0)
  notes        String?
  status       String        @default("UNPAID")
  payments     Payment[]
  openingText  String?
  closingText  String?
  headerColor  String?
  signatureId  String?
  signature    Signature?    @relation(fields: [signatureId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("invoices")
}

model InvoiceItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  name        String
  description String?
  quantity    Float    @default(1)
  unit        String   @default("pcs")
  price       Float    @default(0)
  total       Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("invoice_items")
}

model Payment {
  id        String   @id @default(uuid())
  invoiceId String
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
  amount    Float    @default(0)
  date      DateTime
  method    String   @default("TRANSFER")
  reference String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("payments")
}

model Expense {
  id         String   @id @default(uuid())
  date       DateTime
  name       String
  category   String
  amount     Float    @default(0)
  department String?
  requestBy  String?
  notes      String?
  receipt    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("expenses")
}

model ExpenseRequest {
  id               String               @id @default(uuid())
  number           String               @unique
  date             DateTime
  dueDate          DateTime?
  detailsOfPayment String?
  project          String?
  description      String?
  name             String
  email            String?
  beneficiary      String?
  bankNorek        String?
  rfpCategory      String               @default("OTHERS")
  status           String               @default("PENDING")
  notes            String?
  items            ExpenseRequestItem[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@map("expense_requests")
}

model ExpenseRequestItem {
  id          String         @id @default(uuid())
  requestId   String
  request     ExpenseRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  description String
  amount      Float          @default(0)
  createdAt   DateTime       @default(now())

  @@map("expense_request_items")
}

model FormToken {
  id          String    @id @default(uuid())
  token       String    @unique
  label       String?
  usedAt      DateTime?
  createdById String
  createdAt   DateTime  @default(now())

  @@map("form_tokens")
}
